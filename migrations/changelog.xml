<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Structural changes: tables, indexes, constraints. Run once, never rerun. -->
    <includeAll path="schema" relativeToChangelogFile="true"/>

    <!-- Mutable objects: stored procs, triggers, functions, views. Rerun on change. -->
    <includeAll path="routines" relativeToChangelogFile="true"/>

</databaseChangeLog>